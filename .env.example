# NEXUS Store Environment Configuration

# API Configuration
# Set the base URL for the backend API
# If not set or contains 'demo', the mock API will be used
VITE_API_URL=https://api.nexus-store.demo/v1

# Set to 'true' to force using the mock API (for development/testing)
VITE_USE_MOCK_API=false

# Example real API URL:
# VITE_API_URL=https://api.yourdomain.com/v1

# Note: Create a .env file with your actual values
# Never commit .env files with real credentials to version control
